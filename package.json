{
  "name": "amplitude-rn-experiment",
  "version": "1.8.7",
  "description": "Storage-agnostic React Native Experiment client for Amplitude services",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "experiment-react-native-client.podspec",
    "!android/build",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "test": "jest",
    "generate:version": "genversion --es6 src/gen/version.ts",
    "typescript": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "pack:local": "node -e \"require('fs').mkdirSync('../.packed',{recursive:true})\" && npm pack --pack-destination ../.packed",
    "prepare": "npm run generate:version && bob build",
    "release": "release-it",
    "example": "npm install --prefix example",
    "pods": "cd example && pod-install --quiet",
    "bootstrap": "npm run example && npm run pods"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": "https://github.com/JoaoPauloCMarra/amplitude-rn-experiment",
  "author": "Joao Paulo C. Marra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JoaoPauloCMarra/amplitude-rn-experiment/issues"
  },
  "homepage": "https://github.com/JoaoPauloCMarra/amplitude-rn-experiment#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@amplitude/analytics-connector": "^1.6.4",
    "@amplitude/experiment-core": "^0.13.0",
    "unfetch": "^4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@react-native/babel-preset": "0.83.9",
    "@release-it/conventional-changelog": "^2.0.0",
    "@types/jest": "^29.5.14",
    "baseline-browser-mapping": "2.10.24",
    "caniuse-lite": "1.0.30001791",
    "commitlint": "^11.0.0",
    "eslint": "^8",
    "eslint-config-prettier": "^7.2.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-prettier": "^3.4.1",
    "genversion": "^2.3.1",
    "husky": "^4.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pod-install": "^0.1.0",
    "prettier": "^2.8.8",
    "react": "19.2.5",
    "react-native": "0.83.9",
    "react-native-builder-bob": "^0.41.0",
    "release-it": "^14.2.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "resolutions": {
    "baseline-browser-mapping": "2.10.24",
    "caniuse-lite": "1.0.30001791"
  },
  "jest": {
    "preset": "react-native",
    "testEnvironment": "jsdom",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "setupFiles": [
      "./__mocks__/setup.ts"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "npm run lint && npm run typescript"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true,
      "publishArgs": [
        "--provenance"
      ]
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNExperimentReactNativeClientSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.amplitude.experiment.reactnative"
    },
    "ios": {
      "podspec": "experiment-react-native-client.podspec"
    }
  }
}
